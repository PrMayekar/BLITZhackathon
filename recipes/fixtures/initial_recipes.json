[
  {"model": "recipes.recipe", "pk": 1, "fields": {"title": "Tomato Egg Scramble", "description": "Quick protein-packed breakfast using fresh tomatoes and eggs", "meal_type": "breakfast", "prep_time": 5, "cook_time": 10, "servings": 2, "difficulty": "easy", "health_tags": ["high_protein", "energy_boost"], "is_weekend_special": false, "calories_per_serving": 180, "image_emoji": "🍳", "instructions": "1. Dice tomatoes. 2. Beat eggs with salt and pepper. 3. Heat oil in pan. 4. Sauté tomatoes 2 min. 5. Pour eggs and scramble until cooked. 6. Garnish with coriander and serve hot.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 2, "fields": {"title": "Spinach Dal", "description": "Iron-rich lentil curry with fresh spinach — a weeknight powerhouse", "meal_type": "lunch", "prep_time": 10, "cook_time": 25, "servings": 4, "difficulty": "easy", "health_tags": ["high_protein", "vegan", "heart_healthy", "immunity_boost"], "is_weekend_special": false, "calories_per_serving": 220, "image_emoji": "🍲", "instructions": "1. Boil lentils until soft. 2. Sauté onion, garlic, ginger. 3. Add tomatoes and spices. 4. Add lentils and spinach. 5. Simmer 10 minutes. 6. Temper with cumin.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 3, "fields": {"title": "Aloo Paratha", "description": "Crispy stuffed flatbread with spiced potato filling", "meal_type": "breakfast", "prep_time": 20, "cook_time": 20, "servings": 4, "difficulty": "medium", "health_tags": ["energy_boost", "vegetarian"], "is_weekend_special": true, "calories_per_serving": 310, "image_emoji": "🫓", "instructions": "1. Boil and mash potatoes with spices and coriander. 2. Knead wheat flour dough with water and salt. 3. Stuff potato filling into dough balls. 4. Roll out flat. 5. Cook on hot tawa with butter until golden both sides.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 4, "fields": {"title": "Banana Oat Smoothie", "description": "Creamy energy smoothie with banana, oats and milk", "meal_type": "breakfast", "prep_time": 5, "cook_time": 0, "servings": 1, "difficulty": "easy", "health_tags": ["energy_boost", "vegetarian", "weight_loss"], "is_weekend_special": false, "calories_per_serving": 280, "image_emoji": "🥤", "instructions": "1. Peel banana. 2. Add banana, oats, milk and honey to blender. 3. Blend until smooth. 4. Add ice and blend again. 5. Serve immediately.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 5, "fields": {"title": "Paneer Bhurji", "description": "Scrambled cottage cheese with onions, tomatoes and spices", "meal_type": "any", "prep_time": 10, "cook_time": 15, "servings": 3, "difficulty": "easy", "health_tags": ["high_protein", "vegetarian", "low_carb"], "is_weekend_special": false, "calories_per_serving": 250, "image_emoji": "🧀", "instructions": "1. Crumble paneer into small pieces. 2. Sauté onion, ginger, garlic until golden. 3. Add tomatoes and spices, cook 5 minutes. 4. Add crumbled paneer and mix well. 5. Garnish with coriander. 6. Serve with roti.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 6, "fields": {"title": "Vegetable Fried Rice", "description": "Quick fried rice using leftover rice and mixed vegetables", "meal_type": "dinner", "prep_time": 10, "cook_time": 15, "servings": 3, "difficulty": "easy", "health_tags": ["energy_boost", "vegan"], "is_weekend_special": false, "calories_per_serving": 290, "image_emoji": "🍚", "instructions": "1. Heat oil in wok. 2. Add garlic and mixed vegetables. 3. Stir fry 5 minutes on high heat. 4. Add cooked rice and soy sauce. 5. Toss everything well. 6. Season with salt and pepper and serve.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 7, "fields": {"title": "Tomato Soup", "description": "Velvety tomato soup — perfect for using up ripe or near-expiry tomatoes", "meal_type": "any", "prep_time": 10, "cook_time": 20, "servings": 4, "difficulty": "easy", "health_tags": ["vegan", "immunity_boost", "heart_healthy"], "is_weekend_special": false, "calories_per_serving": 120, "image_emoji": "🍅", "instructions": "1. Sauté onion and garlic in butter. 2. Add chopped tomatoes and cook 10 minutes. 3. Add broth and simmer 10 minutes. 4. Blend until smooth. 5. Season with salt, pepper, and basil. 6. Serve hot with crusty bread.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 8, "fields": {"title": "Chicken Curry", "description": "Classic Indian chicken curry with aromatic spices", "meal_type": "dinner", "prep_time": 15, "cook_time": 35, "servings": 4, "difficulty": "medium", "health_tags": ["high_protein"], "is_weekend_special": false, "calories_per_serving": 380, "image_emoji": "🍛", "instructions": "1. Marinate chicken in yogurt and spices for 30 minutes. 2. Sauté onions until golden brown. 3. Add ginger-garlic paste and tomatoes. 4. Add marinated chicken pieces. 5. Cook on medium heat 25 minutes. 6. Garnish and serve with rice or roti.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 9, "fields": {"title": "Palak Paneer", "description": "Creamy spinach curry with cottage cheese chunks", "meal_type": "dinner", "prep_time": 15, "cook_time": 25, "servings": 4, "difficulty": "medium", "health_tags": ["high_protein", "vegetarian", "heart_healthy", "immunity_boost"], "is_weekend_special": true, "calories_per_serving": 290, "image_emoji": "🥬", "instructions": "1. Blanch spinach and blend to puree. 2. Fry paneer cubes until golden. 3. Sauté onion, tomato with spices. 4. Add spinach puree and cook 5 minutes. 5. Add fried paneer and cream. 6. Simmer 5 minutes and serve.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 10, "fields": {"title": "Banana Pancakes", "description": "Fluffy weekend pancakes with ripe bananas and honey", "meal_type": "breakfast", "prep_time": 10, "cook_time": 15, "servings": 2, "difficulty": "easy", "health_tags": ["vegetarian", "energy_boost"], "is_weekend_special": true, "calories_per_serving": 320, "image_emoji": "🥞", "instructions": "1. Mash ripe bananas thoroughly. 2. Mix with flour, beaten egg, milk, and baking powder. 3. Heat butter in non-stick pan. 4. Pour batter and cook until bubbles form. 5. Flip and cook 2 more minutes. 6. Serve stacked with honey.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 11, "fields": {"title": "Garlic Bread", "description": "Crispy garlic bread — great snack using bread before it goes stale", "meal_type": "snack", "prep_time": 5, "cook_time": 10, "servings": 4, "difficulty": "easy", "health_tags": ["vegetarian"], "is_weekend_special": false, "calories_per_serving": 180, "image_emoji": "🥖", "instructions": "1. Mix butter with minced garlic, salt, and dried herbs. 2. Spread generously on bread slices. 3. Place on a baking tray. 4. Bake at 180°C for 8-10 minutes until golden. 5. Serve immediately while hot.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 12, "fields": {"title": "Masala Omelette", "description": "Spiced Indian omelette with onion, green chilli and coriander", "meal_type": "breakfast", "prep_time": 5, "cook_time": 8, "servings": 1, "difficulty": "easy", "health_tags": ["high_protein", "low_carb", "energy_boost"], "is_weekend_special": false, "calories_per_serving": 210, "image_emoji": "🍳", "instructions": "1. Beat eggs well with salt. 2. Add chopped onion, green chilli, tomato, and coriander to eggs. 3. Heat oil in pan. 4. Pour egg mixture and spread evenly. 5. Cook until set on bottom. 6. Fold and serve hot.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 13, "fields": {"title": "Lemon Rice", "description": "Tangy South Indian lemon rice — quick lunch using leftover rice", "meal_type": "lunch", "prep_time": 5, "cook_time": 10, "servings": 2, "difficulty": "easy", "health_tags": ["vegan", "immunity_boost"], "is_weekend_special": false, "calories_per_serving": 240, "image_emoji": "🍋", "instructions": "1. Heat oil and add mustard seeds until they splutter. 2. Add curry leaves, peanuts, and turmeric. 3. Add cooked rice and mix. 4. Squeeze fresh lemon juice generously. 5. Mix well and season with salt. 6. Serve warm.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 14, "fields": {"title": "Mango Lassi", "description": "Refreshing yogurt drink with ripe mangoes", "meal_type": "snack", "prep_time": 5, "cook_time": 0, "servings": 2, "difficulty": "easy", "health_tags": ["vegetarian", "immunity_boost"], "is_weekend_special": false, "calories_per_serving": 190, "image_emoji": "🥭", "instructions": "1. Add mango pulp to blender. 2. Add yogurt and milk. 3. Add sugar and cardamom powder. 4. Blend until smooth and frothy. 5. Add ice cubes and blend briefly. 6. Serve chilled.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 15, "fields": {"title": "Rajma Chawal", "description": "Hearty kidney bean curry with rice — Sunday comfort food", "meal_type": "lunch", "prep_time": 15, "cook_time": 40, "servings": 4, "difficulty": "medium", "health_tags": ["high_protein", "vegan", "heart_healthy", "weight_loss"], "is_weekend_special": true, "calories_per_serving": 360, "image_emoji": "🫘", "instructions": "1. Soak rajma overnight and boil until soft. 2. Sauté onion until golden brown. 3. Add ginger-garlic paste and tomatoes with spices. 4. Add boiled rajma and water. 5. Pressure cook 10 minutes. 6. Simmer until thick. Serve over steamed rice.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 16, "fields": {"title": "Mushroom Soup", "description": "Creamy mushroom soup — great way to use mushrooms near expiry", "meal_type": "dinner", "prep_time": 10, "cook_time": 25, "servings": 4, "difficulty": "easy", "health_tags": ["vegetarian", "immunity_boost", "low_carb"], "is_weekend_special": false, "calories_per_serving": 160, "image_emoji": "🍄", "instructions": "1. Sauté onion and garlic in butter. 2. Add sliced mushrooms and cook until soft. 3. Add broth and simmer 15 minutes. 4. Blend partially for texture. 5. Add cream, season well. 6. Serve hot with bread.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 17, "fields": {"title": "Poha", "description": "Light flattened rice breakfast with vegetables and peanuts", "meal_type": "breakfast", "prep_time": 10, "cook_time": 15, "servings": 2, "difficulty": "easy", "health_tags": ["vegan", "energy_boost", "weight_loss"], "is_weekend_special": false, "calories_per_serving": 200, "image_emoji": "🌾", "instructions": "1. Wash and drain poha until soft. 2. Sauté mustard seeds, curry leaves, and peanuts. 3. Add onion, potato, and green chilli. 4. Add drained poha and turmeric. 5. Mix gently and cook 5 minutes. 6. Squeeze lemon and garnish with coriander.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 18, "fields": {"title": "Grilled Chicken Salad", "description": "Light protein salad with grilled chicken and fresh vegetables", "meal_type": "lunch", "prep_time": 15, "cook_time": 15, "servings": 2, "difficulty": "easy", "health_tags": ["high_protein", "low_carb", "weight_loss", "heart_healthy"], "is_weekend_special": false, "calories_per_serving": 280, "image_emoji": "🥗", "instructions": "1. Marinate chicken in herbs, lemon, and olive oil. 2. Grill 6 minutes each side. 3. Slice into strips. 4. Toss lettuce, tomato, and cucumber. 5. Add chicken strips. 6. Drizzle with olive oil and lemon. Season and serve.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 19, "fields": {"title": "Pasta Primavera", "description": "Italian pasta tossed with seasonal vegetables in garlic olive oil", "meal_type": "dinner", "prep_time": 10, "cook_time": 20, "servings": 3, "difficulty": "easy", "health_tags": ["vegetarian", "energy_boost"], "is_weekend_special": false, "calories_per_serving": 340, "image_emoji": "🍝", "instructions": "1. Cook pasta al dente in salted water. 2. Sauté minced garlic in olive oil. 3. Add mixed vegetables and cook 5 minutes. 4. Toss drained pasta with vegetables. 5. Add cheese and black pepper. 6. Serve hot.", "created_at": "2024-01-01T00:00:00Z"}},
  {"model": "recipes.recipe", "pk": 20, "fields": {"title": "Avocado Toast", "description": "Healthy toast with mashed avocado — nutritious quick breakfast", "meal_type": "breakfast", "prep_time": 8, "cook_time": 3, "servings": 1, "difficulty": "easy", "health_tags": ["vegan", "heart_healthy", "weight_loss"], "is_weekend_special": false, "calories_per_serving": 260, "image_emoji": "🥑", "instructions": "1. Toast bread slices until golden. 2. Mash avocado with lemon juice, salt and pepper. 3. Spread generously on toast. 4. Top with chilli flakes and seeds. 5. Add a poached egg on top if desired. 6. Serve immediately.", "created_at": "2024-01-01T00:00:00Z"}},
